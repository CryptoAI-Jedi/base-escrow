# --- Chain / Network ---
NETWORK_NAME=base-sepolia
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

# --- Escrow contract (EVM/Base) ---
ESCROW_CONTRACT_ADDRESS=0xREPLACE_WITH_ESCROW_CONTRACT_ADDRESS

# --- Resolver service (called by CRE) ---
RESOLVER_BASE_URL=http://127.0.0.1:8080
RESOLVER_API_TOKEN=REPLACE_WITH_RANDOM_HEX_TOKEN

# --- Signer used by resolver for onchain tx submission ---
RESOLVER_SIGNER_PRIVATE_KEY=0xREPLACE_WITH_PRIVATE_KEY
RESOLVER_SIGNER_ADDRESS=0xREPLACE_WITH_SIGNER_ADDRESS

# --- Optional ---
POLL_INTERVAL_SECONDS=30
LOG_LEVEL=INFO
